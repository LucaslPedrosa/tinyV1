[configuration]

entry_symbol = "tinyv1_library_init"
compatibility_minimum = "4.6"

[libraries]

linux.debug.x86_64 = "res://bin/libtinyv1.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libtinyv1.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/libtinyv1.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libtinyv1.windows.template_release.x86_64.dll"
